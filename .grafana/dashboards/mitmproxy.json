{
  "id": null,
  "uid": "mitmproxy-dashboard",
  "title": "mitmproxy",
  "tags": ["mitmproxy", "ralph"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Log Rate Over Time",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "elasticsearch", "uid": "mitmproxy" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "refId": "A",
          "query": "*",
          "alias": "log rate",
          "metrics": [
            { "type": "count", "id": "1" }
          ],
          "bucketAggs": [
            {
              "type": "date_histogram",
              "field": "@timestamp",
              "id": "2",
              "settings": {
                "interval": "auto",
                "min_doc_count": "0",
                "trimEdges": "0"
              }
            }
          ],
          "timeField": "@timestamp"
        }
      ]
    },
    {
      "id": 2,
      "type": "barchart",
      "title": "event.action Breakdown",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "elasticsearch", "uid": "mitmproxy" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 80
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xTickLabelRotation": -45,
        "xTickLabelSpacing": 0,
        "showValue": "auto",
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "query": "*",
          "alias": "",
          "metrics": [
            { "type": "count", "id": "1" }
          ],
          "bucketAggs": [
            {
              "type": "terms",
              "field": "event.action.keyword",
              "id": "2",
              "settings": {
                "size": "10",
                "order": "desc",
                "orderBy": "1",
                "min_doc_count": "1"
              }
            }
          ],
          "timeField": "@timestamp"
        }
      ]
    }
  ]
}
